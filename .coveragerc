[run]
branch = True
source =
    src
omit =
    */__init__.py
    src/schemes/*
    src/comms/*
    src/experiments/*
    src/app/*

[report]
show_missing = True
skip_covered = False
omit =
    */__init__.py
    src/schemes/*
    src/comms/*
    src/experiments/*
    src/app/*

[html]
directory = coverage/html
